# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

PROJECT_NAME=Quaddle

# Local dev uses SQLite. For production, swap in a PostgreSQL URL, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/quaddle
DATABASE_URL=sqlite:///./quaddle.db

# Generate a strong key, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=1440